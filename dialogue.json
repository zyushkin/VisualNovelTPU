        }
      }
    },

    "возвращение_в_общежитие": {
      "nodes": {
        "0": {
          "speaker": "Рассказчик",
          "text": "Ты возвращаешься в общежитие. День был насыщенным и интересным. Ты ужинаешь, отдыхаешь и умываешься. За окном темнеет. Ты ложишься спать.",
          "portraits": [
            {
              "file": "sprite_TPU_chan_test.png",
              "x": 400,
              "y": 250,
              "scale": 0.8
            }
          ],
          "background": "sprite_dormitory_room.jpg",
