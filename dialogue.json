          "background": "sprite_libr.jpg",
          "next": -1,
          "options": [
            {
              "text": "Взять учебник по химии",
              "nextDialog": "библиотека_химия"
            },
            {
              "text": "Взять роман",
              "nextDialog": "библиотека_роман"
            }
          ]
        }
      }
    },

    "библиотека_химия": {
      "nodes": {
        "0": {
          "speaker": "ТПУ-тян",
          "text": "Спасибо, я возьму учебник по органической химии. Пригодится.",
