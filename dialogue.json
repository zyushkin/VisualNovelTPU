          "next": -1,
          "options": []
        }
      }
    },

    "компьютерный_класс": {
      "nodes": {
        "0": {
          "speaker": "Преподаватель",
          "text": "ТПУ-тян, садись. Сегодня будем разбирать алгоритмы сортировки. Открой ноутбук и запусти среду разработки.",
          "portraits": [
            {
              "file": "sprite_programm_teacher.png",
              "x": 1150,
              "y": 250,
              "scale": 0.4
            },
            {
              "file": "sprite_TPU_chan_test.png",
              "x": 150,
              "y": 250,
              "scale": 0.8
            }
          ],
          "background": "sprite_computer_class.png",
          "next": 1,
          "options": []
        },
        "1": {
          "speaker": "Рассказчик",
          "text": "Занятие проходит спокойно. Ты успешно справляешься с заданием. После пары у тебя перерыв. Куда направишься?",
          "portraits": [
            {
              "file": "sprite_TPU_chan_test.png",
              "x": 400,
              "y": 250,
              "scale": 0.8
            }
          ],
          "background": "sprite_computer_class.png",
          "next": -1,
          "options": [
            {
              "text": "Пойти в библиотеку",
              "nextDialog": "библиотека"
            },
            {
              "text": "Пойти пообедать",
              "nextDialog": "столовая"
            }
          ]
        }
      }
    },

    "библиотека": {
      "nodes": {
        "0": {
          "speaker": "Библиотекарь",
          "text": "Здравствуйте! Чем могу помочь? У нас есть отличные учебники по химии, если вы готовитесь к сегодняшней паре. А также есть художественная литература.",
