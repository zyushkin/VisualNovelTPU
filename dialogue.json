            {
              "file": "sprite_TPU_chan_test.png",
              "x": 400,
              "y": 250,
              "scale": 0.8
            }
          ],
          "background": "sprite_canteen.jpg",
          "next": -1,
          "options": [
            {
              "text": "Пойти сразу на химию",
              "nextDialog": "столовая_химия"
            },
            {
              "text": "Погулять во дворе",
              "nextDialog": "столовая_гулять"
            }
